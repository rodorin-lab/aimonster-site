// AI MONSTER FACTORY — membership + admin data model.
// Dev: SQLite (zero-setup, file-based) via DATABASE_URL="file:./dev.db".
// Prod: switch DATABASE_URL to a real Postgres (Neon/Supabase) and change
// `provider` below to "postgresql" — the schema itself is portable.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ── NextAuth core tables ──────────────────────────────────────────
model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  hashedPassword String? // null for Google-OAuth-only accounts
  rank           String    @default("RANCHER") // VISITOR is unauthenticated; logged-in starts at RANCHER
  points         Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  favorites     Favorite[]
  purchases     Purchase[]
  votes         Vote[]
  comments      RanchLogComment[]
  rankEvents    RankEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Commerce ────────────────────────────────────────────────────
model Subscription {
  id                     String    @id @default(cuid())
  userId                 String
  stripeCustomerId       String?
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  status                 String // active / canceled / past_due / trialing
  currentPeriodEnd       DateTime?
  rank                   String // SUPPORTER / KEEPER / LEGEND
  cancelAtPeriodEnd      Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Favorite {
  id           String   @id @default(cuid())
  userId       String
  creatureSlug String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, creatureSlug])
}

model Purchase {
  id                String    @id @default(cuid())
  userId            String
  packSlug          String
  stripePaymentId   String?
  amountCents       Int
  currency          String    @default("usd")
  status            String // succeeded / pending / failed / refunded
  downloadToken     String?
  downloadExpiresAt DateTime?
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Community ───────────────────────────────────────────────────
model Vote {
  id           String   @id @default(cuid())
  userId       String
  campaignSlug String
  optionSlug   String
  weight       Int      @default(1)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignSlug])
}

model RanchLogComment {
  id        String   @id @default(cuid())
  userId    String
  logSlug   String
  body      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Audit trail for rank changes — no dedicated UI; query directly when needed.
model RankEvent {
  id        String   @id @default(cuid())
  userId    String
  fromRank  String
  toRank    String
  reason    String // "subscription" / "signup" / manual DB edit note
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
